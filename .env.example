# =============================================================================
# Supabase (Vite — must use VITE_ prefix)
# In SQL Editor, run migrations in order from supabase/migrations/
# (include 20260412100000_execute_paper_sell.sql and 20260412200000_sold_stocks_and_execute_paper_sell.sql for sells / sold_stocks.)
# =============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional alias for the same dashboard “anon” / publishable key:
# VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Gemini — Vite (chat text + live voice replies)
# Text chat: use a non-TTS model (e.g. gemini-2.5-flash). If you mistakenly set a *-tts* id here,
# the app still uses gemini-2.5-flash for text.
# Voice (TTS): Gemini 2.5 Flash TTS — default gemini-2.5-flash-preview-tts (see speech-generation docs).
# Optional prebuilt voice name (e.g. Kore, Puck, Charon): https://ai.google.dev/gemini-api/docs/speech-generation
# =============================================================================
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# VITE_GEMINI_TTS_VOICE=Kore

# =============================================================================
# ElevenLabs — Flask server (Live voice in chat; key stays on server)
# Voice ID: ElevenLabs → Voices / Voice Lab → copy id.
# =============================================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional model (default eleven_multilingual_v2):
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: send a default voice id from the browser (overrides server default if set in JSON body)
# VITE_ELEVENLABS_VOICE_ID=

# =============================================================================
# Finnhub — Python server only (never expose to Vite). No spaces/quotes around the key.
# =============================================================================
FINNHUB_API_KEY=

# =============================================================================
# Flask — must match Vite’s /api proxy (default 5050).
# Do NOT use 5000 on macOS: AirPlay Receiver binds there and returns HTTP 403.
# =============================================================================
FLASK_PORT=5050

# =============================================================================
# Optional: deployed backend origin only (no `/api` suffix). Leave unset in local dev (Vite proxies /api to Flask).
# =============================================================================
# VITE_API_URL=https://your-backend.example.com
