# Supabase (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Finnhub — used only by the Python server (never expose the secret to Vite)
FINNHUB_API_KEY=

# Optional: deployed API origin only (no `/api`). In local dev, leave this unset so
# the app uses `/api/...` on the Vite dev server (proxied to Flask) — do NOT set this
# to http://localhost:5000 in dev; it causes CORS. Production example:
# VITE_API_URL=https://your-backend.example.com
