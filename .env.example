# Supabase (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Finnhub — Python server only (never expose to Vite)
FINNHUB_API_KEY=

# Flask port — must match Vite’s /api proxy (default 5050).
# Do NOT use 5000 on macOS: AirPlay Receiver binds there and returns HTTP 403 to your API.
FLASK_PORT=5050

# Optional: production API origin only (no `/api`). Leave unset in local dev.
# VITE_API_URL=https://your-backend.example.com
